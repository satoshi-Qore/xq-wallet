# ==============================================================================
# XQ Wallet — Environment Variables Template
#
# Copy this file to .env.local and fill in real values.
#
#   cp .env.local.example .env.local
#
# RULES:
#   - NEXT_PUBLIC_* vars are exposed to the browser. Never put secrets in them.
#   - Server-only secrets (no NEXT_PUBLIC_ prefix) are never sent to the client.
#   - NEVER commit .env.local to version control.
# ==============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=XQ Wallet
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_ENVIRONMENT=development   # development | testnet | mainnet

# ─── QoreChain Network ────────────────────────────────────────────────────────
NEXT_PUBLIC_QORECHAIN_RPC_URL=
NEXT_PUBLIC_QORECHAIN_CHAIN_ID=
NEXT_PUBLIC_QORECHAIN_EXPLORER_URL=
NEXT_PUBLIC_QORECHAIN_WS_URL=         # Optional: WebSocket RPC endpoint

# ─── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=             # XQ Wallet backend API (if applicable)

# ─── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TESTNET=true
NEXT_PUBLIC_ENABLE_DEVTOOLS=true

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=

# ─── Server-side secrets (never exposed to the browser) ───────────────────────
# Add server-only secrets below — no NEXT_PUBLIC_ prefix
# ENCRYPTION_KEY=
# DATABASE_URL=
